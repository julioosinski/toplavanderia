<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Configuração para serviços locais (HTTP) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">192.168.4.1</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">192.168.43.0</domain>
        <domain includeSubdomains="true">192.168.100.0</domain>
        <domain includeSubdomains="true">169.254.0.0</domain>
        <domain includeSubdomains="true">tpgweb.io</domain>
    </domain-config>

    <!-- HTTPS: trust anchors do sistema (OCSP desabilitado via CieloSslWorkaround no DX8000) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
